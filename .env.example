# Supabase — Project Settings → API (en supabase.com, dentro de tu proyecto)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-public-key

# La anon key está diseñada para ser pública (queda protegida por las
# políticas RLS, no por el secreto), así que es normal que termine dentro
# del sitio ya compilado. Lo que NO debe existir nunca en este repo, en el
# frontend, ni en ningún archivo versionado es la "service_role key" de
# Supabase: esa clave se salta todas las políticas RLS.
